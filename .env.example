# Airtable Personal Access Token
# Create at: https://airtable.com/create/tokens
# Required scopes: schema.bases:read, data.records:read
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Comma-separated Airtable base IDs
AIRTABLE_BASE_IDS=appXXXXXXXXXXXXXX

# Optional: use field names instead of field IDs as record keys (default: true)
# AIRTABLE_USE_FIELD_IDS=false
